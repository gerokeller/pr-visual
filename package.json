{
  "name": "pr-visual",
  "version": "1.0.0",
  "description": "Claude Code plugin — visual PR documentation with AI-generated Playwright scenarios, annotated screenshots, and captioned walkthrough videos.",
  "main": "scripts/pr-visual/index.ts",
  "bin": {
    "pr-visual": "./bin/pr-visual"
  },
  "files": [
    "bin/",
    "scripts/",
    "skills/",
    "hooks/",
    ".claude-plugin/",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "pr-visual": "tsx scripts/pr-visual/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "postinstall": "npx playwright install chromium 2>/dev/null || true"
  },
  "keywords": [
    "claude-code-plugin",
    "pr",
    "visual",
    "screenshots",
    "playwright",
    "documentation"
  ],
  "author": "Gero Keller",
  "license": "MIT",
  "homepage": "https://github.com/gerokeller/pr-visual",
  "repository": {
    "type": "git",
    "url": "https://github.com/gerokeller/pr-visual.git"
  },
  "bugs": {
    "url": "https://github.com/gerokeller/pr-visual/issues"
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
